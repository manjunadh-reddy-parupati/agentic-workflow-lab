# =============================================================================
# DocGovernance.ai — SINGLE SOURCE OF TRUTH FOR ALL CONFIGURATION
# =============================================================================
# This one file holds every setting for the whole project: backend, frontend,
# the local Weaviate RAG, and the Azure OpenAI LLM.
#
#   1. Copy this file to ".env" in the same folder:   cp .env.example .env
#   2. Fill in the secret values (Azure OpenAI) below.
#   3. Everything (Docker Compose, the Python backend, and Vite) reads from it.
#
# The real ".env" is git-ignored so your API keys are NEVER committed. Only this
# ".env.example" (with blank secrets) is published to the public repo.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure OpenAI (LLM used to validate each section) — SECRETS, keep private
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AZURE_OPENAI_MODEL=gpt-5.2
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# -----------------------------------------------------------------------------
# Local RAG (Weaviate) — the vector store the Source of Truth is indexed into
# -----------------------------------------------------------------------------
# NOTE: when running everything via Docker Compose, the backend container reaches
# Weaviate by its service name ("weaviate"); compose overrides WEAVIATE_HOST for
# you. The value below is what's used when you run the backend on your own machine.
WEAVIATE_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051
RAG_COLLECTION=SourceOfTruth
VERBA_TOP_K=3

# -----------------------------------------------------------------------------
# Service ports (host machine)
# -----------------------------------------------------------------------------
BACKEND_PORT=8001
FRONTEND_PORT=5173
VERBA_PORT=8000

# -----------------------------------------------------------------------------
# Frontend dev server (only used by `npm run dev`; Docker uses nginx instead)
# -----------------------------------------------------------------------------
VITE_API_PROXY_TARGET=http://localhost:8001
